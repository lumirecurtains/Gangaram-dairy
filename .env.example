# ============================================================
# ENVIRONMENT VARIABLES — Gangaram
# Copy this to .env.local and fill in your values
# ============================================================

# --- Firebase Client (Module 1) ---
# Found in Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (Module 1) ---
# Generate at Firebase Console → Project Settings → Service Accounts
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Razorpay (Module 3) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Your own Razorpay Route platform account ID (for rider/platform share transfers)
RAZORPAY_PLATFORM_ACCOUNT_ID=

# --- WhatsApp Notifications (Module 3) ---
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# --- Cron & Admin (Module 6) ---
CRON_SECRET=

# --- Google Cloud Storage (Module 6) ---
GCS_BUCKET_NAME=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=

# --- Site URL (Module 11) ---
NEXT_PUBLIC_SITE_URL=

# --- SMS Provider (Module 12) ---
SMS_API_KEY=
SMS_SENDER_ID=
SMS_API_URL=https://api.msg91.com/api/v5/flow/

# --- VAPID Keys / Web Push (Module 12) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Optional: Anthropic / AI Support Chat (Module 15) ---
# ANTHROPIC_API_KEY=
