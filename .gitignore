# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
AGENTS.md
CLAUDE.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (sensitive — never commit local or production values)
.env.local
.env.production
.env.development
.env.test

# Keep .env.example tracked (it's a public template)

# vercel
.vercel

# firebase
.firebase
firebase-debug.log

# typescript
*.tsbuildinfo
next-env.d.ts
